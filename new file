<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <title>Banana Center</title>
    <!-- アイコンを使うための準備 (Font Awesome) -->
    <link rel="stylesheet" href="https://cloudflare.com">
    
    <style>
        body, html {
            height: 100%;
            margin: 0;
            display: flex;          /* 1. Flexboxを使う */
            justify-content: center; /* 2. 左右の中央 */
            align-items: center;     /* 3. 上下の中央 */
            background-color: #1a1a1a; /* 背景をダークにして「かっこよく」 */
        }

        .banana-icon {
            font-size: 100px;       /* 大きさ */
            color: #FFE135;         /* バナナ色 */
            filter: drop-shadow(0 0 20px rgba(255, 225, 53, 0.5)); /* 光らせてかっこよく */
            transition: transform 0.3s ease;
        }

    
        .banana-icon:hover {
            transform: scale(1.2) rotate(-10deg);
            cursor: pointer;
        }
    </style>
</head>
<body>

    <!-- バナナアイコン本体 -->
    <i class="fa-solid fa-banana banana-icon"></i>

</body>
</html>
