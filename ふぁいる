<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>BANANA CLAN</title>

<style>
body {
  margin: 0;
  font-family: Arial;
  background: radial-gradient(circle at top, #0f172a, black);
  color: white;
  text-align: center;
}

header {
  padding: 60px 20px;
}

h1 {
  font-size: 50px;
  color: #facc15;
  text-shadow: 0 0 20px #facc15;
}

p {
  opacity: 0.8;
}

.btn {
  background: #facc15;
  color: black;
  padding: 15px 25px;
  border-radius: 10px;
  text-decoration: none;
  font-weight: bold;
  display: inline-block;
  margin-top: 20px;
  transition: 0.3s;
}

.btn:hover {
  background: white;
}

.section {
  padding: 40px 20px;
}

.card {
  background: #111827;
  margin: 10px auto;
  padding: 15px;
  border-radius: 15px;
  max-width: 300px;
  box-shadow: 0 0 10px #000;
}

.card:hover {
  transform: scale(1.05);
  transition: 0.3s;
}
</style>

</head>
<body>

<header>
  <h1>🍌 BANANA CLAN</h1>
  <p>We are the strongest team.</p>
  <a class="btn" href="#">Discordに参加</a>
</header>

<div class="section">
  <h2>👥 Members</h2>

  <div class="card">Sho（Leader）</div>
  <div class="card">Player2</div>
  <div class="card">Player3</div>

</div>

<div class="section">
  <h2>🎮 Games</h2>
  <p>Apex / Roblox / Fortnite</p>
</div>

</body>
</html>
